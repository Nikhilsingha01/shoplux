{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --env-file=../../.env --enable-source-maps ./dist/index.mjs",
    "start:prod": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clerk/express": "^2.1.16",
    "@clerk/shared": "^4.11.0",
    "@supabase/supabase-js": "^2.106.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "axios": "^1.16.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "http-proxy-middleware": "^4.0.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "resend": "^6.12.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "catalog:",
    "@types/ws": "^8.18.1",
    "cross-env": "^7.0.3",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0"
  }
}
