{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_BACKEND_RAILWAY_URL/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://YOUR_BACKEND_RAILWAY_URL/uploads/:path*"
    },
    {
      "source": "/((?!assets/|favicon.ico|logo.svg|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
